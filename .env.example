# ==========================================================================
# Configuração do Sistema de Almoxarifado / Patrimônio
# Copie este arquivo para `.env` e ajuste os valores.  NUNCA versione o `.env`.
# ==========================================================================

# Ambiente: development | production | testing
FLASK_ENV=development

# Chave secreta da aplicação (sessões, CSRF). Gere uma forte em produção:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-esta-chave-em-producao

# --------------------------------------------------------------------------
# Banco de dados
# --------------------------------------------------------------------------
# Em DESENVOLVIMENTO, se DATABASE_URL ficar vazio, o sistema usa SQLite local
# automaticamente (instance/almoxarifado.sqlite3) — sem precisar de Postgres.
#
# Em PRODUÇÃO use PostgreSQL, ex.:
#   DATABASE_URL=postgresql+psycopg://almox:senha@db:5432/almoxarifado
DATABASE_URL=

# Credenciais usadas pelo docker-compose para subir o PostgreSQL
POSTGRES_DB=almoxarifado
POSTGRES_USER=almox
POSTGRES_PASSWORD=troque-esta-senha

# --------------------------------------------------------------------------
# Redis (cache, rate limit, fila). Opcional em dev (cai para memória).
# --------------------------------------------------------------------------
REDIS_URL=

# --------------------------------------------------------------------------
# E-mail (alertas, convites). Opcional.
# --------------------------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=nao-responder@exemplo.com.br

# --------------------------------------------------------------------------
# Segurança / produção
# --------------------------------------------------------------------------
# Força HTTPS e headers estritos (deixe false em dev local sem TLS).
FORCE_HTTPS=false
# Hosts permitidos (separados por vírgula) em produção.
ALLOWED_HOSTS=

# Observabilidade (opcional)
SENTRY_DSN=

# Marca / identidade do produto (white-label padrão da instalação)
APP_NAME=Almoxarifado
